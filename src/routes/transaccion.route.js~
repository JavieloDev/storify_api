const express = require('express');
const router = express.Router();
const {getService} = require('../middlewares/headers')
const {Op} = require('sequelize');
const {getSequelizeInstance} = require("../libs/sequelize");

// ============================
// CARGAR
// POST /transacciones/all/:solicitudId
// ============================
router.post('/all/:solicitudId', async (req, res, next) => {
    try {
        const transService = getService(req, 'TRANSACCION');
        const {solicitudId} = req.params;
        console.log(solicitudId)
        const {page = 1, limit = 10, ...filters} = req.query;

        const baseFilters = {
            ...filters,
            solicitudId: Number(solicitudId)
        };

        const result = await transService.findAll({
            page: Number(page),
            limit: Number(limit),
            filters: baseFilters
        });

        res.json({
            status: result.status,
            code: result.code,
            message: result.message,
            data: result.data,
            pagination: result.pagination
        });
    } catch (error) {
        next(error);
    }
});

// ============================
// CREAR
// POST /transacciones/create
// ============================
router.post('/create', async (req, res, next) => {
    const sequelize = getSequelizeInstance('db11');
    const t = await sequelize.transaction();

    try {
        const transService = getService(req, 'TRANSACCION');

        const transaccionData = {
            date: req.body.date,
            destinatario: req.body.destinatario,
            monto: req.body.monto,
            localizacion: req.body.localizacion,
            solicitudId: req.body.solicitudId
        };

        if (!transaccionData.solicitudId) {
            return res.status(400).json({
                status: 'error',
                message: 'solicitudId es requerido'
            });
        }

        const created = await transService.create(transaccionData, {transaction: t});

        res.status(201).json({
            status: 'success',
            message: 'Transacción creada correctamente',
            data: created
        });
    } catch (error) {
        next(error);
    }
});

// ============================
// ACTUALIZAR
// PUT /transacciones/:id
// ============================
router.put('/:id', async (req, res, next) => {
    const sequelize = getSequelizeInstance('db11');
    const t = await sequelize.transaction();

    try {
        const transService = getService(req, 'TRANSACCION');
        const {id} = req.params;
        const transaccion = await transService.findById(id);

        if (!transaccion) {
            await t.rollback();
            return res.status(404).json({message: 'Transaccion no encontrada'});
        }

        const transaccionData = {
            date: req.body.date,
            destinatario: req.body.destinatario,
            monto: req.body.monto,
            localizacion: req.body.localizacion,
            solicitudId: req.body.solicitudId
        };

        const updated = await transService.update(id, transaccionData, {transaction: t});
        await t.commit();

        res.json({
            status: 'success',
            code: 200,
            message: 'Transacción actualizada correctamente',
            data: updated
        });
    } catch (error) {
        await t.rollback();
        console.error('Error actualizando transaccion:', error);
        next(error);
    }
});


// Eliminar una transacción
router.delete('/:id', async (req, res, next) => {
    try {
        const transService = getService(req, 'TRANSACCION');
        const {id} = req.params;

        const deleted = await transService.delete(id);

        if (!deleted) {
            return res.status(404).json({
                status: 'error',
                message: 'Transacción no encontrada'
            });
        }

        res.json({
            status: 'success',
            message: 'Transacción eliminada correctamente'
        });
    } catch (error) {
        next(error);
    }
});

module.exports = router;
